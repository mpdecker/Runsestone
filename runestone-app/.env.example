# PostgreSQL (app connection — matches docker-compose host ports)
DATABASE_URL=postgres://runestone:runestone@localhost:5442/runestone
POSTGRES_DB=runestone
POSTGRES_USER=runestone
POSTGRES_PASSWORD=runestone
POSTGRES_PORT=5442

# Neo4j
NEO4J_URL=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=runestone
NEO4J_AUTH=neo4j/runestone
NEO4J_HTTP_PORT=7475
NEO4J_BOLT_PORT=7688

# Runestone API server (remote mode / docker compose)
RUNESTONE_API_TOKEN=change-me-in-production
RUNESTONE_SERVER_PORT=3000

# Embeddings
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PORT=11434
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM (chat, summarization, extraction)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2

# Clipper HTTP server (optional; default dev token if unset)
# CLIPPER_AUTH_TOKEN=your-secret-token
