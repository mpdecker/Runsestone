# Database (matches docker-compose.yml host ports)
DATABASE_URL=postgres://runestone:runestone@localhost:5442/runestone
NEO4J_URL=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=runestone

# Embeddings
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM (chat, summarization, extraction)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2

# Clipper HTTP server (optional; generated if unset)
# CLIPPER_AUTH_TOKEN=your-secret-token
