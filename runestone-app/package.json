{
  "name": "runestone-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm test && cargo test --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:ios": "tauri ios dev",
    "tauri:ios:build": "tauri ios build",
    "tauri:android": "tauri android dev",
    "tauri:android:build": "tauri android build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node tests/e2e/smoke.mjs && node tests/e2e/server-integration.mjs",
    "generate:bindings": "node scripts/check-bindings.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
